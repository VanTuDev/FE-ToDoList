# FE API
# Cách A (gọi thẳng BE):
# NEXT_PUBLIC_API_URL=https://be-todolist-hhz4.onrender.com
#
# Cách B (proxy Next.js /api/* -> BACKEND_URL):
# NEXT_PUBLIC_API_URL=
BACKEND_URL=https://be-todolist-hhz4.onrender.com

# Gemini (server-side, KHÔNG public)
GEMINI_API_KEY=your_gemini_api_key_here
# Nếu bạn đang lỡ dùng tên biến cũ, hệ thống vẫn hỗ trợ (không khuyến nghị):
# NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-3-flash-preview

